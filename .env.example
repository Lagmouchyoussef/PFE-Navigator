# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_NAME=pfe_navigator
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
# Full URL form (used by docker-compose; overrides individual DB_* vars):
DATABASE_URL=postgres://postgres:postgres@db:5432/pfe_navigator

# ─── Redis / Channels ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# ─── Security (production only) ───────────────────────────────────────────────
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ─── Email (optional) ─────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=secret

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
